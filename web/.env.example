# OpenAI APIキーを設定する（必須）。
OPENAI_API_KEY=
# OpenAIモデル名を設定する（任意。未設定時はgpt-4o-mini）。
OPENAI_MODEL=gpt-4o-mini

# Firebase Admin（サーバー専用・必須）— 次のどちらか一方
# A) プレーン JSON（1行・{ で始まり } で終わる。Vercel の値欄は引用符で囲まない）
FIREBASE_SERVICE_ACCOUNT_JSON=
# B) 上がどうしても通らないとき: キー JSON ファイルを base64（改行なし）にしたもの（例: macOS は base64 -i key.json | tr -d '\n'）
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# Vercel: 変数の Environment に Production にチェック → Save → Deployments から Redeploy。Preview のみだと本番 URL では読めません。
# ローカル: web/.env.local を編集したら next dev を再起動。.env.local はデプロイされない。Git / チャットに貼らない。

# Firebase クライアント設定（必須・ブラウザ用。Firebase Console の「ウェブアプリ」からコピー）。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
