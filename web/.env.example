# OpenAI APIキーを設定する（必須）。
OPENAI_API_KEY=
# OpenAIモデル名を設定する（任意。未設定時はgpt-4o-mini）。
OPENAI_MODEL=gpt-4o-mini

# Firebase Admin（サーバー専用・必須）
# サービスアカウントの JSON を「実改行のない1行」にした文字列として入れる（.env なら全体を '...' で囲んでも可）。
# ローカル: web/.env.local を編集したら next dev を再起動。.env.local はデプロイされない。
# Vercel: Settings → Environment Variables の値欄に「引用符なしの JSON 1行」を貼り、Production に付けて Redeploy。
# Git / チャットに貼らない。
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase クライアント設定（必須・ブラウザ用。Firebase Console の「ウェブアプリ」からコピー）。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
