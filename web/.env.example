# OpenAI APIキーを設定する（必須）。
OPENAI_API_KEY=
# OpenAIモデル名を設定する（任意。未設定時はgpt-4o-mini）。
OPENAI_MODEL=gpt-4o-mini

# Firebase Admin（サーバー専用・必須）
# --- おすすめ: サービスアカウント JSON を「1本の文字列」にする（PC に JSON ファイルを置かない運用）---
# Vercel の Environment Variables にだけ登録し、チャットや Git には載せない。
# Vercel の Firebase 公式インテグレーションを使うと、ここに相当する値が自動で入る場合があります（ダッシュボードの Environment Variables で名前を確認）。
# 手動の場合は、GCP で発行したサービスアカウント JSON の全文を「Vercel の画面だけ」に貼る（チャットやリポジトリに貼らない）。
# 連携で別名の変数が付いた場合は、Vercel 上でこの変数名に合わせるか、下の3分割と同様の内容にマッピングする。
FIREBASE_SERVICE_ACCOUNT_JSON=
# （代替名）一部のテンプレートで使われることがある。
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- 代替: 3 つに分ける（従来どおり。FIREBASE_SERVICE_ACCOUNT_JSON と併用しない）---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# 改行は \n エスケープ形式で設定する。
FIREBASE_PRIVATE_KEY=

# Firebase クライアント設定（必須・ブラウザ用。Firebase Console の「ウェブアプリ」からコピー）。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

