# OpenAI APIキーを設定する（必須）。
OPENAI_API_KEY=
# OpenAIモデル名を設定する（任意。未設定時はgpt-4o-mini）。
OPENAI_MODEL=gpt-4o-mini

# Firebase Admin（サーバー専用・必須）
# サービスアカウントの JSON ファイルの中身を、そのまま1本の文字列として入れる。
# ローカルは web/.env.local、本番は Vercel の Environment Variables。Git / チャットに貼らない。
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase クライアント設定（必須・ブラウザ用。Firebase Console の「ウェブアプリ」からコピー）。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
